PORT=5000

# Database Configuration (Set DATABASE_URL for Neon/Supabase, or use separate variables for local)
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=sentra

# JWT Authentication Config
JWT_SECRET=sentra-super-secret-key-1234
ADMIN_PASSWORD=admin123

# LibreTranslate URL (Optional: Leave empty to bypass external translation API)
# To use a public instance or local instance, specify the full URL, e.g. https://libretranslate.com/
LIBRETRANSLATE_URL=

# Database Seeding (Set to true in local development/demo to allow seed.js execution)
ENABLE_SEED_DATA=false
